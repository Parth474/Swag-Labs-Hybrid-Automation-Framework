<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="ProblemUserSuite" parallel="tests" thread-count="2">
	
	<listeners>
		<listener class-name="listner.ReusableListner"/>
	</listeners>
	
  <test name="Problem User Test">
    <parameter name="browser" value="chrome"/>
    <parameter name="user" value="problem_user"/>
  	<classes>
  		<class name="tests.LoginTest"/>
  		<class name="tests.ProductCatalogTest"/>
  		<class name="tests.CartTest"/>
  		<class name="tests.ProductPageTest"/>
  		<class name="tests.CheckOutTest"/>
  	</classes>
  </test>
</suite>
