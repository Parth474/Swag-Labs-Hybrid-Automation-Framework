<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Selenium-Grid-Standalone-Suite" parallel="tests" thread-count="2">

    <listeners>
        <listener class-name="listner.ReusableListner"/>
    </listeners>
    
    <!--Global Parameter-->
   	<parameter name="user" value="standard_user"/>
	
    <test name="Windows-Chrome">
        <parameter name="browser" value="chrome"/>
        <parameter name="os" value="windows"/>
        
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.ProductCatalogTest"/>
            <class name="tests.ProductPageTest"/>
        </classes>
    </test>

	<test name="Windows-Firefox">
        <parameter name="browser" value="firefox"/>
        <parameter name="os" value="windows"/>
        
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.ProductCatalogTest"/>
            <class name="tests.ProductPageTest"/>
        </classes>
    </test>
</suite>
