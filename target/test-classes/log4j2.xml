<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <!-- ===================== -->
    <!--   Global Properties   -->
    <!-- ===================== -->
    <Properties>
        <Property name="basePath">./logs</Property>
        <Property name="pattern">%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n</Property>
    </Properties>
    
    <!--Appenders-->
    <Appenders>
        <!-- Console Appender -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${pattern}" />
        </Console>

        <!-- Rolling File Appender -->
        <RollingFile name="File"
                     fileName="${basePath}/automation.log"
                     filePattern="${basePath}/archive/automation-%d{yyyy-MM-dd}-%i.log.gz">

            <PatternLayout pattern="${pattern}" />

            <Policies>
                <!-- Roll daily -->
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <!-- Roll if size exceeds 5MB -->
                <SizeBasedTriggeringPolicy size="5MB"/>
            </Policies>

            <!-- Keep last 10 archived files -->
            <DefaultRolloverStrategy max="10"/>

        </RollingFile>

    </Appenders>

    <!-- ===================== -->
    <!--        Loggers        -->
    <!-- ===================== -->
    <Loggers>

        <!-- Reduce Selenium internal noise -->
        <Logger name="org.openqa.selenium" level="WARN"/>
        <Logger name="org.apache.http" level="WARN"/>

        <!-- Root Logger -->
        <Root level="Info"> <!-- Levels ->> All < Trace < Debug < Info < Warn < Error < Off -->
        	<!-- -->
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Root>

    </Loggers>

</Configuration>